{
  "swagger": "2.0",
  "info": {
    "title": "Assign Pre-Quantity API",
    "version": "1.0.0",
    "description": "PLM Style on adet (MinimumQuantity) atama servisi. Bir StyleId alir; PLM STYLE + StyleColorways verisini ceker, IDM temasindan Cluster/Alt_Sezon okur, costingDB On Adet Parametreleri tablosundan kademeli (L1/L2/L3) adet cozer ve sonucu PLM STYLECOLORWAYS + STYLE.NumericValue1 alanlarina yazar."
  },
  "host": "assignprequant-243c26425a65.herokuapp.com",
  "basePath": "/api",
  "schemes": ["https"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "tags": [
    { "name": "Assign Pre-Quantity", "description": "On adet atama uc noktalari" }
  ],
  "paths": {
    "/assign-prequantity": {
      "post": {
        "tags": ["Assign Pre-Quantity"],
        "summary": "On adet ata (styleId govdede)",
        "description": "StyleId govdede gonderilir. dryRun true ise PLM'e yazilmaz, sadece hesap doner.",
        "operationId": "assignPreQuantityBody",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/AssignRequest" }
          }
        ],
        "responses": {
          "200": { "description": "Hesap/atama sonucu", "schema": { "$ref": "#/definitions/AssignResult" } },
          "400": { "description": "styleId eksik", "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "404": { "description": "Style bulunamadi", "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "500": { "description": "Sunucu veya PLM hatasi", "schema": { "$ref": "#/definitions/ErrorResponse" } }
        }
      }
    },
    "/assign-prequantity/{styleId}": {
      "post": {
        "tags": ["Assign Pre-Quantity"],
        "summary": "On adet ata (styleId path uzerinden)",
        "operationId": "assignPreQuantityPathPost",
        "produces": ["application/json"],
        "parameters": [
          { "name": "styleId", "in": "path", "required": true, "type": "integer", "format": "int64", "description": "PLM StyleId" },
          { "name": "dryRun", "in": "query", "required": false, "type": "boolean", "description": "true ise PLM'e yazmaz" }
        ],
        "responses": {
          "200": { "description": "Hesap/atama sonucu", "schema": { "$ref": "#/definitions/AssignResult" } },
          "400": { "description": "styleId eksik", "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "404": { "description": "Style bulunamadi", "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "500": { "description": "Sunucu veya PLM hatasi", "schema": { "$ref": "#/definitions/ErrorResponse" } }
        }
      },
      "get": {
        "tags": ["Assign Pre-Quantity"],
        "summary": "On adet onizleme veya atama (styleId path uzerinden)",
        "operationId": "assignPreQuantityPathGet",
        "produces": ["application/json"],
        "parameters": [
          { "name": "styleId", "in": "path", "required": true, "type": "integer", "format": "int64", "description": "PLM StyleId" },
          { "name": "dryRun", "in": "query", "required": false, "type": "boolean", "description": "true ise PLM'e yazmaz (onizleme)" }
        ],
        "responses": {
          "200": { "description": "Hesap/atama sonucu", "schema": { "$ref": "#/definitions/AssignResult" } },
          "400": { "description": "styleId eksik", "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "404": { "description": "Style bulunamadi", "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "500": { "description": "Sunucu veya PLM hatasi", "schema": { "$ref": "#/definitions/ErrorResponse" } }
        }
      }
    }
  },
  "definitions": {
    "AssignRequest": {
      "type": "object",
      "required": ["styleId"],
      "properties": {
        "styleId": { "type": "integer", "format": "int64", "description": "PLM StyleId" },
        "dryRun": { "type": "boolean", "description": "true ise PLM'e yazmaz, sadece hesap doner" }
      }
    },
    "Dimensions": {
      "type": "object",
      "properties": {
        "brandId": { "type": "integer" },
        "divisionId": { "type": "integer" },
        "subCategoryId": { "type": "integer" },
        "productSubSubCategoryId": { "type": "integer" },
        "seasonId": { "type": "integer" }
      }
    },
    "ColorwayResult": {
      "type": "object",
      "properties": {
        "styleColorwayId": { "type": "integer" },
        "currentQty": { "type": "number" },
        "colorwayStatus": { "type": "integer" },
        "lifestyle": { "type": "integer" },
        "cluster": { "type": "string" },
        "altSezon": { "type": "string" },
        "newQty": { "type": "integer", "description": "Hesaplanan adet (varsayilan 0)" },
        "changed": { "type": "boolean", "description": "currentQty ile newQty farkli mi" },
        "level": { "type": "string", "description": "Eslesme seviyesi L1 L2 veya L3" },
        "note": { "type": "string" },
        "error": { "type": "string" }
      }
    },
    "ColorwayError": {
      "type": "object",
      "properties": {
        "styleColorwayId": { "type": "integer" },
        "error": { "type": "string" }
      }
    },
    "Patched": {
      "type": "object",
      "properties": {
        "colorways": { "type": "integer" },
        "styleTotal": { "type": "boolean" }
      }
    },
    "AssignResult": {
      "type": "object",
      "properties": {
        "styleId": { "type": "integer", "format": "int64" },
        "styleCode": { "type": "string" },
        "status": { "type": "integer" },
        "forcedZero": { "type": "boolean", "description": "Style.Status 103 ise tum adetler 0" },
        "filter": { "type": "string", "description": "001 patch yapildi, 000 hata veya degisiklik yok" },
        "hasValidationError": { "type": "boolean" },
        "hasChange": { "type": "boolean" },
        "dimensions": { "$ref": "#/definitions/Dimensions" },
        "totalQty": { "type": "integer" },
        "colorways": { "type": "array", "items": { "$ref": "#/definitions/ColorwayResult" } },
        "errors": { "type": "array", "items": { "$ref": "#/definitions/ColorwayError" } },
        "patched": { "$ref": "#/definitions/Patched" },
        "dryRun": { "type": "boolean" }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "properties": {
        "error": { "type": "string" }
      }
    }
  }
}
