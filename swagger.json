{
  "swagger": "2.0",
  "info": {
    "title": "Assign Pre-Quantity API",
    "version": "1.0.0",
    "description": "PLM Style on adet (MinimumQuantity) atama servisi. Bir StyleId alir; PLM STYLE + StyleColorways verisini ceker, IDM temasindan Cluster/Alt_Sezon okur, costingDB On Adet Parametreleri tablosundan kademeli (L1/L2/L3) adet cozer ve sonucu PLM STYLECOLORWAYS + STYLE.NumericValue1 alanlarina yazar."
  },
  "host": "assignprequant-243c26425a65.herokuapp.com",
  "basePath": "/api",
  "schemes": ["https"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "tags": [
    { "name": "Assign Pre-Quantity", "description": "On adet atama uc noktalari" }
  ],
  "paths": {
    "/assign-prequantity": {
      "post": {
        "tags": ["Assign Pre-Quantity"],
        "summary": "On adet ata (styleId govdede)",
        "description": "StyleId govdede gonderilir. dryRun=true ise PLM'e yazilmaz, sadece hesap doner.",
        "operationId": "assignPreQuantityBody",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/AssignRequest" }
          }
        ],
        "responses": {
          "200": { "description": "Hesap/atama sonucu", "schema": { "$ref": "#/definitions/AssignResult" } },
          "400": { "description": "styleId eksik", "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "404": { "description": "Style bulunamadi", "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "500": { "description": "Sunucu/PLM hatasi", "schema": { "$ref": "#/definitions/ErrorResponse" } }
        }
      }
    },
    "/assign-prequantity/{styleId}": {
      "post": {
        "tags": ["Assign Pre-Quantity"],
        "summary": "On adet ata (styleId path'te)",
        "operationId": "assignPreQuantityPathPost",
        "parameters": [
          { "name": "styleId", "in": "path", "required": true, "type": "integer", "description": "PLM StyleId" },
          { "name": "dryRun", "in": "query", "required": false, "type": "boolean", "description": "true ise PLM'e yazmaz" }
        ],
        "responses": {
          "200": { "description": "Hesap/atama sonucu", "schema": { "$ref": "#/definitions/AssignResult" } },
          "400": { "description": "styleId eksik", "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "404": { "description": "Style bulunamadi", "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "500": { "description": "Sunucu/PLM hatasi", "schema": { "$ref": "#/definitions/ErrorResponse" } }
        }
      },
      "get": {
        "tags": ["Assign Pre-Quantity"],
        "summary": "On adet onizleme/atama (styleId path'te)",
        "operationId": "assignPreQuantityPathGet",
        "parameters": [
          { "name": "styleId", "in": "path", "required": true, "type": "integer", "description": "PLM StyleId" },
          { "name": "dryRun", "in": "query", "required": false, "type": "boolean", "description": "true ise PLM'e yazmaz (onizleme)" }
        ],
        "responses": {
          "200": { "description": "Hesap/atama sonucu", "schema": { "$ref": "#/definitions/AssignResult" } },
          "400": { "description": "styleId eksik", "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "404": { "description": "Style bulunamadi", "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "500": { "description": "Sunucu/PLM hatasi", "schema": { "$ref": "#/definitions/ErrorResponse" } }
        }
      }
    }
  },
  "definitions": {
    "AssignRequest": {
      "type": "object",
      "required": ["styleId"],
      "properties": {
        "styleId": { "type": "integer", "example": 15344, "description": "PLM StyleId" },
        "dryRun": { "type": "boolean", "example": false, "description": "true ise PLM'e yazmaz, sadece hesap doner" }
      }
    },
    "ColorwayResult": {
      "type": "object",
      "properties": {
        "styleColorwayId": { "type": "integer", "example": 17012 },
        "currentQty": { "type": "number", "example": 0 },
        "colorwayStatus": { "type": "integer", "example": 1 },
        "lifestyle": { "type": "integer", "example": 3 },
        "cluster": { "type": "string", "example": "013" },
        "altSezon": { "type": "string", "example": "SS1" },
        "newQty": { "type": "integer", "example": 120, "description": "Hesaplanan adet (varsayilan 0)" },
        "changed": { "type": "boolean", "example": true, "description": "currentQty != newQty" },
        "level": { "type": "string", "example": "L1-alt_kategori", "description": "Eslesme seviyesi (L1/L2/L3)" },
        "note": { "type": "string", "example": "L1-alt_kategori (1 kayit)" },
        "error": { "type": "string", "example": "" }
      }
    },
    "AssignResult": {
      "type": "object",
      "properties": {
        "styleId": { "type": "integer", "example": 15344 },
        "styleCode": { "type": "string", "example": "TS1270002196" },
        "status": { "type": "integer", "example": 2 },
        "forcedZero": { "type": "boolean", "example": false, "description": "Style.Status=103 ise tum adetler 0" },
        "filter": { "type": "string", "example": "001", "description": "001 = patch yapildi/yapilacak, 000 = hata veya degisiklik yok (patch atlandi)" },
        "hasValidationError": { "type": "boolean", "example": false },
        "hasChange": { "type": "boolean", "example": true },
        "dimensions": {
          "type": "object",
          "properties": {
            "brandId": { "type": "integer", "example": 8 },
            "divisionId": { "type": "integer", "example": 6 },
            "subCategoryId": { "type": "integer", "example": 20 },
            "productSubSubCategoryId": { "type": "integer", "example": 56 },
            "seasonId": { "type": "integer", "example": 11 }
          }
        },
        "totalQty": { "type": "integer", "example": 120 },
        "colorways": { "type": "array", "items": { "$ref": "#/definitions/ColorwayResult" } },
        "errors": { "type": "array", "items": { "type": "object" } },
        "patched": {
          "type": "object",
          "properties": {
            "colorways": { "type": "integer", "example": 1 },
            "styleTotal": { "type": "boolean", "example": true }
          }
        },
        "dryRun": { "type": "boolean", "example": false }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "properties": {
        "error": { "type": "string", "example": "styleId zorunludur (path, query veya body)." }
      }
    }
  }
}
