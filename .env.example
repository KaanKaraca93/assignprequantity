# TÜM DEĞİŞKENLER OPSİYONELDİR — hiçbir env ayarı yapmadan deploy edebilirsiniz.
# Varsayılanlar koda gömülüdür (PLM PRD tenant + costingDB prod adresi).

# PLM tenant seçimi: test -> TST tenant. Boş/başka değer -> PRD (varsayılan).
# PLM_ENV=test

# HTTP portu (Heroku otomatik atar, elle vermeye gerek yok)
# PORT=3099

# costingDB (Ön Adet Parametreleri) REST API kökü (yalnızca adres değişirse)
# COSTING_DB_API_URL=https://costingdb-8538ae5b78bc.herokuapp.com/api
